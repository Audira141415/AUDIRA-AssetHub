// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("Operator")
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendor {
  id        String   @id @default(cuid())
  name      String
  type      String
  email     String?
  phone     String?
  status    String   @default("Active")
  
  // Enterprise VRM Fields
  rating              Float?
  contractExpiry      DateTime?
  totalSpent          Float?
  accountManagerName  String?
  accountManagerEmail String?
  techSupportL1Phone  String?
  techSupportL2Phone  String?
  
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String
  code        String
  description String?
  color       String?  @default("#6C63FF")
  icon        String?  @default("Layers")
  
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String
  type      String   // "Site", "Building", "Floor", "Room", "Rack"
  parentLoc String?  // Optional parent ID
  capacity  Int?     // Rack capacity in U
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id         String   @id @default(cuid())
  tag        String   @unique
  hostname   String?
  status     String   @default("Active")
  
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id])
  
  warranty   String?
  rack       String?
  uPosition  String?
  
  parentAssetId String?
  parentAsset   Asset?  @relation("SubrackHierarchy", fields: [parentAssetId], references: [id])
  childAssets   Asset[] @relation("SubrackHierarchy")
  
  // Financial Fields
  purchaseCost    Float?
  purchaseDate    DateTime?
  salvageValue    Float?
  usefulLifeYears Int?
  
  // Enterprise ITAM: Lifecycle & Maintenance
  lifecycleState  String   @default("Production") // Procurement, In-Transit, In-Storage, Production, RMA, Retired
  eolDate         DateTime?
  eosDate         DateTime?
  slaLevel        String?  // e.g., 24x7x4 NBD
  contractNumber  String?
  
  // Enterprise ITAM: CMDB & Topology
  businessApp     String?  // e.g., Core Banking System
  businessOwner   String?
  techOwner       String?
  upstreamPowerId String?  // ID of upstream PDU or UPS
  upstreamNetId   String?  // ID of upstream Switch
  
  // Enterprise ITAM: FinOps & Audit
  costCenter      String?
  ownershipType   String   @default("Owned") // Owned, Leased, Cloud
  lastAuditDate   DateTime?
  
  // Enterprise ITAM: Capacity & Environment
  powerWatts      Float?
  weightKg        Float?
  coolingBTU      Float?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tickets    Ticket[]
  movements  Movement[]
  ips        IPAddress[]
  licenses   AssetLicense[]
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String   @default("Medium")
  status      String   @default("Open")
  type        String   @default("Repair")
  
  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id])
  
  reportedBy      String?
  assignedTo      String?
  
  resolutionNotes String?
  resolvedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model License {
  id              String   @id @default(cuid())
  name            String
  productKey      String?
  vendor          String?
  totalSeats      Int      @default(1)
  purchaseCost    Float?
  
  purchaseDate    DateTime?
  expiryDate      DateTime?
  
  assets          AssetLicense[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AssetLicense {
  id         String   @id @default(cuid())
  
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  assignedAt DateTime @default(now())
  notes      String?
  
  @@unique([assetId, licenseId])
}

model Movement {
  id          String   @id @default(cuid())
  
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  
  fromLoc     String?
  toLoc       String?
  
  date        DateTime @default(now())
  user        String   @default("System User")
  notes       String?
}

model Subnet {
  id          String   @id @default(cuid())
  name        String
  cidr        String   @unique
  vlan        Int?
  description String?
  ips         IPAddress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IPAddress {
  id          String   @id @default(cuid())
  address     String   @unique
  status      String   @default("Available") // Available, Reserved, Active
  
  subnetId    String
  subnet      Subnet   @relation(fields: [subnetId], references: [id])
  
  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key         String   @id
  value       String
  category    String   @default("General")
  description String?
  updatedAt   DateTime @updatedAt
}

